{
  "name": "nuur-home-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:ipv4": "vite --host 127.0.0.1",
    "dev:3000": "vite --host 127.0.0.1 --port 3000",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop:icon": "node scripts/generate-win-icon.mjs",
    "desktop:dev": "npm run desktop:icon && concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on tcp:127.0.0.1:5173 && electron electron/main.cjs --dev-url=http://127.0.0.1:5173\"",
    "desktop:build": "npm run desktop:icon && npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^38.7.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.4",
    "vite": "^8.0.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.nuurhome.erp",
    "productName": "Nuur Home ERP",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NuurHome-ERP-${version}.${ext}"
    }
  }
}
